# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# Same DB the Streamlit app used — data carries over.
#
# Runtime uses Supabase's TRANSACTION pooler (port 6543). For Prisma you MUST
# keep `pgbouncer=true` — transaction pooling can't use prepared statements.
# The pooler username is  postgres.<PROJECT-REF>  (project ref is in the user).
# URL-encode the password (e.g. @ -> %40, # -> %23).
# Keep sslmode=require on both URLs — it forces TLS for data in transit.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[URL-ENCODED-PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"

# Prisma migrations / `db pull` / `db push` need a DIRECT (non-pooled) connection.
# Use the SESSION pooler (port 5432) on the same host — it's IPv4-friendly,
# unlike the db.<ref>.supabase.co direct host (IPv6-only without the add-on).
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[URL-ENCODED-PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

# ── Auth.js (NextAuth v5) ─────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-me"

# Google OAuth client. Rotate the secret you pasted in chat before using it.
AUTH_GOOGLE_ID="xxxxxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-xxxxxxxx"

# Public URL of the app. Locally http://localhost:3000, on Vercel your domain.
# Auth.js usually infers this on Vercel; set it explicitly if sign-in misbehaves.
AUTH_URL="http://localhost:3000"

# ── SMTP for group-invite emails (optional) ───────────────────────────────────
# Same Gmail app-password setup the Streamlit app used. Leave blank to skip email.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USERNAME="you@gmail.com"
SMTP_PASSWORD="your gmail app password"
EMAIL_FROM="you@gmail.com"
